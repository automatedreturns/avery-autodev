# Application
APP_NAME=AutoDev
APP_VERSION=0.1.0
DEBUG=False

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///./avery.db

# Security (IMPORTANT: Generate a new SECRET_KEY for production)
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8000"]

# AI Provider API Keys (configure at least one)
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=
GEMINI_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Agent Configuration
AGENT_MAX_TOKENS=8000

# Repository Storage
REPOS_BASE_PATH=/tmp/autodev-repos

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
SESSION_SECRET_KEY=

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Backend URL (for GitHub Actions webhooks)
BACKEND_URL=http://localhost:8000

# Authentication Methods
AUTH_PASSWORD_ENABLED=True
AUTH_MAGIC_LINK_ENABLED=False
AUTH_GOOGLE_ENABLED=False

# SMTP for Magic Link (optional)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=AutoDev

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# CI/CD Integration
AVERY_API_TOKEN=
